<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="container">
  <div class="page-header">
    <h1>Login History</h1>
    <p>Your last <%= records.length %> sign-in <%= records.length === 1 ? 'event' : 'events' %></p>
  </div>

  <% if (records.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">🔒</div>
      <h2>No history yet</h2>
      <p>Login activity will appear here once you've signed in.</p>
    </div>
  <% } else { %>
    <!-- Security summary -->
    <%
      const failed = records.filter(r => r.status === 'failed').length;
      const last = records[0];
    %>
    <div style="display:flex; gap:1.25rem; margin-bottom:2rem; flex-wrap:wrap;">
      <div style="background:white; border:1px solid var(--border); border-radius:10px; padding:1.1rem 1.5rem; flex:1; min-width:160px;">
        <div style="font-family:'Playfair Display',serif; font-size:1.75rem; font-weight:900; color:<%= failed > 0 ? '#c8452b' : '#1a7a45' %>"><%= failed === 0 ? '✓' : failed %></div>
        <div style="font-size:0.82rem; color:var(--muted); margin-top:0.2rem;"><%= failed === 0 ? 'No failed attempts' : 'Failed attempt' + (failed > 1 ? 's' : '') %></div>
      </div>
      <div style="background:white; border:1px solid var(--border); border-radius:10px; padding:1.1rem 1.5rem; flex:1; min-width:160px;">
        <div style="font-family:'DM Mono',monospace; font-size:1rem; font-weight:600; color:var(--ink); margin-top:0.15rem;">
          <%= last.loginTime.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year:'numeric' }) %>
        </div>
        <div style="font-size:0.82rem; color:var(--muted); margin-top:0.2rem;">Most recent login</div>
      </div>
      <div style="background:white; border:1px solid var(--border); border-radius:10px; padding:1.1rem 1.5rem; flex:1; min-width:160px;">
        <div style="font-family:'DM Mono',monospace; font-size:0.95rem; font-weight:600;">
          <%=  last.deviceInfo && last.deviceInfo.includes('Chrome') ? '🟢' : last.deviceInfo && last.deviceInfo.includes('Firefox') ? '🦊' : last.deviceInfo && last.deviceInfo.includes('Safari') ? '🍎' : '🖥️' %>
          <%= last.deviceInfo || 'Unknown' %>
        </div>
        <div style="font-size:0.82rem; color:var(--muted); margin-top:0.2rem;">Last device</div>
      </div>
    </div>

    <div style="overflow-x:auto;">
      <table class="history-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Date & Time</th>
            <th>IP Address</th>
            <th>Device / Browser</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% records.forEach((record, index) => { %>
            <tr>
              <td style="color:var(--muted); font-family:'DM Mono',monospace; font-size:0.78rem;"><%= index + 1 %></td>
              <td>
                <div style="font-weight:600; font-size:0.875rem;">
                  <%= record.loginTime.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </div>
                <div style="font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--muted); margin-top:0.1rem;">
                  <%= record.loginTime.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
                </div>
              </td>
              <td>
                <span style="font-family:'DM Mono',monospace; font-size:0.82rem; background:var(--cream); padding:0.2rem 0.5rem; border-radius:4px; border:1px solid var(--border);">
                  <%= record.ipAddress || '—' %>
                </span>
              </td>
              <td>
                <span class="device-icon">
                  <% if (record.deviceInfo && record.deviceInfo.includes('Chrome')) { %>🟢
                  <% } else if (record.deviceInfo && record.deviceInfo.includes('Firefox')) { %>🦊
                  <% } else if (record.deviceInfo && record.deviceInfo.includes('Safari')) { %>🍎
                  <% } else if (record.deviceInfo && record.deviceInfo.includes('Edge')) { %>🔵
                  <% } else if (record.deviceInfo && record.deviceInfo.includes('iPhone')) { %>📱
                  <% } else if (record.deviceInfo && record.deviceInfo.includes('Android')) { %>📱
                  <% } else { %>🖥️<% } %>
                </span>
                <%= record.deviceInfo || 'Unknown Device' %>
              </td>
              <td>
                <span class="status-badge <%= record.status === 'success' ? 'status-success' : 'status-failed' %>">
                  <%= record.status === 'success' ? '✓ Success' : '✗ Failed' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p style="font-size:0.78rem; color:var(--muted); margin-top:1rem; text-align:right;">Showing last 50 events</p>
  <% } %>

  <div style="margin-top:2rem;">
    <a href="/auth/profile" class="btn btn-outline btn-sm">← Back to Profile</a>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
