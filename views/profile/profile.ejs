<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="container" style="max-width:820px;">
  <div class="page-header">
    <h1>My Profile</h1>
    <p>Manage your account information</p>
  </div>

  <!-- Profile card -->
  <div class="profile-card">
    <div class="profile-cover" style="background: linear-gradient(135deg, var(--nss-blue) 0%, var(--nss-blue-mid) 60%, #1b3a6b 100%); display:flex; align-items:center; justify-content:flex-end; padding:0 1.5rem; gap:0.75rem; border-bottom:3px solid var(--nss-saffron);">
      <img src="/images/nss-logo.jpeg" alt="NSS" style="height:52px;width:52px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,153,51,0.5);opacity:0.85;" />
      <img src="/images/rungta-logo.jpeg" alt="Rungta" style="height:40px;width:70px;object-fit:contain;border-radius:4px;background:white;padding:2px;opacity:0.85;" />
    </div>
    <div class="profile-body">
      <div class="profile-avatar-lg" id="avatar-preview-wrap">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.name %>" id="avatar-preview-img" />
        <% } else { %>
          <span id="avatar-initials"><%= user.name.charAt(0).toUpperCase() %></span>
        <% } %>
      </div>

      <div class="profile-display-name"><%= user.name %></div>
      <div class="profile-email"><%= user.email %></div>
      <% if (user.bio) { %>
        <p class="profile-bio"><%= user.bio %></p>
      <% } %>

      <div class="profile-stats">
        <div class="stat">
          <div class="stat-value"><%= blogCount %></div>
          <div class="stat-label">Stories</div>
        </div>
        <div class="stat">
          <div class="stat-value"><%= commentCount %></div>
          <div class="stat-label">Comments</div>
        </div>
        <div class="stat">
          <div class="stat-value"><%= user.role === 'admin' ? '★' : '✦' %></div>
          <div class="stat-label"><%= user.role === 'admin' ? 'Admin' : 'Member' %></div>
        </div>
        <% if (lastLogin) { %>
          <div class="stat">
            <div class="stat-value" style="font-size:0.85rem; font-family:'DM Mono',monospace;">
              <%= lastLogin.loginTime.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
            </div>
            <div class="stat-label">Last Login</div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Edit profile form — multipart for avatar upload -->
  <div class="form-card" style="max-width:100%; margin:0;">
    <h2 style="font-family:'Playfair Display',serif; font-size:1.3rem; font-weight:700; margin-bottom:1.5rem;">Edit Profile</h2>

    <form action="/auth/profile" method="POST" enctype="multipart/form-data" novalidate>

      <!-- Avatar upload -->
      <div class="form-group">
        <label class="form-label">Profile Photo <span style="color:var(--muted); font-weight:400; text-transform:none;">(optional · max 2 MB)</span></label>
        <div class="avatar-upload-row">
          <!-- Live preview -->
          <div class="avatar-upload-preview" id="avatar-thumb">
            <% if (user.avatar) { %>
              <img src="<%= user.avatar %>" alt="avatar" id="avatar-thumb-img" />
            <% } else { %>
              <span id="avatar-thumb-initial"><%= user.name.charAt(0).toUpperCase() %></span>
            <% } %>
          </div>
          <div class="avatar-upload-controls">
            <label class="btn btn-outline btn-sm avatar-file-label" for="avatar-file">
              📷 Choose Photo
            </label>
            <input type="file" id="avatar-file" name="avatar"
              accept="image/jpeg,image/jpg,image/png,image/webp"
              style="display:none;" />
            <p class="avatar-upload-hint">JPG, PNG or WebP · max 2 MB<br>Uploaded to Cloudinary and auto-cropped to a square.</p>
            <% if (user.avatar) { %>
              <p class="avatar-current-note">✓ Current photo stored on Cloudinary</p>
            <% } %>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Display Name</label>
        <input type="text" name="name" class="form-input"
          value="<%= user.name %>" minlength="2" maxlength="50" required />
      </div>

      <div class="form-group">
        <label class="form-label">Email <span style="color:var(--muted); font-weight:400; text-transform:none;">(read-only)</span></label>
        <input type="email" class="form-input" value="<%= user.email %>"
          disabled style="opacity:0.6; cursor:not-allowed;" />
      </div>

      <div class="form-group">
        <label class="form-label">Bio <span style="color:var(--muted); font-weight:400; text-transform:none; letter-spacing:0;">(optional)</span></label>
        <textarea name="bio" class="form-textarea" style="min-height:90px;"
          placeholder="Tell the NSS community a bit about yourself…"
          maxlength="300"><%= user.bio || '' %></textarea>
        <div class="char-count"><span id="bio-count"><%= (user.bio || '').length %></span> / 300</div>
      </div>

      <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
        <button type="submit" class="btn btn-nss">Save Changes</button>
        <a href="/blogs/my" class="btn btn-outline">View My Blogs</a>
        <a href="/auth/login-history" class="btn btn-ghost btn-sm">Login History →</a>
      </div>
    </form>
  </div>
</div>

<script>
  // Bio char counter
  const bioInput = document.querySelector('textarea[name="bio"]');
  const bioCount = document.getElementById('bio-count');
  bioInput?.addEventListener('input', () => { bioCount.textContent = bioInput.value.length; });

  // Avatar live preview
  const avatarFile  = document.getElementById('avatar-file');
  const thumbImg    = document.getElementById('avatar-thumb-img');
  const thumbInit   = document.getElementById('avatar-thumb-initial');
  const bigWrap     = document.getElementById('avatar-preview-wrap');

  avatarFile?.addEventListener('change', () => {
    const file = avatarFile.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      // Update small thumb
      if (thumbImg) {
        thumbImg.src = e.target.result;
      } else {
        // No existing img — create one
        const img = document.createElement('img');
        img.src = e.target.result;
        img.id  = 'avatar-thumb-img';
        if (thumbInit) thumbInit.replaceWith(img);
        else document.getElementById('avatar-thumb').appendChild(img);
      }
      // Update big profile avatar too
      const bigImg  = bigWrap.querySelector('img');
      const bigSpan = bigWrap.querySelector('span');
      if (bigImg) {
        bigImg.src = e.target.result;
      } else if (bigSpan) {
        const newImg = document.createElement('img');
        newImg.src = e.target.result;
        bigSpan.replaceWith(newImg);
      }
    };
    reader.readAsDataURL(file);
  });
</script>

<%- include('../partials/footer') %>
</body>
</html>
