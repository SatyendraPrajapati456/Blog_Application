<%- include('partials/head') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="container">

  <!-- Admin notice banner -->
  <% if (isAdmin && !isAuthor) { %>
    <div class="admin-notice">
      <span class="admin-notice-icon">🛡️</span>
      <div>
        <strong>Admin View</strong> — You are viewing this blog as the NSS Disciplinary Admin.
        You have full control to edit or remove this content.
      </div>
    </div>
  <% } %>

  <!-- Blog Header -->
  <div class="blog-detail-header">
    <% if (blog.coverImage) { %>
      <div class="blog-cover-wrap" style="margin-bottom:2rem; border-radius:10px; overflow:hidden; border:1px solid var(--border); max-height:460px;">
        <img src="<%= blog.coverImage %>"
          alt="<%= blog.title %> cover"
          style="width:100%; max-height:460px; object-fit:cover; display:block;"
          onerror="this.closest('.blog-cover-wrap').style.display='none'" />
      </div>
    <% } %>
    <h1><%= blog.title %></h1>
    <div class="blog-meta">
      <span class="blog-meta-author">By <span><%= blog.author ? blog.author.name : 'Unknown' %></span></span>
      <span style="color: var(--border);">·</span>
      <span class="blog-meta-date">
        <%= blog.createdAt.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      </span>
      <% if (blog.category) { %>
        <span class="category-badge"><%= blog.category %></span>
      <% } %>
      <% if (blog.updatedAt.getTime() !== blog.createdAt.getTime()) { %>
        <span style="color: var(--muted); font-size: 0.78rem;">(edited)</span>
      <% } %>
      <% if (isAdmin && !isAuthor) { %>
        <span class="admin-tag">🛡 Admin Control</span>
      <% } %>
    </div>
  </div>

  <!-- Blog Content -->
  <div class="blog-content">
    <% blog.content.split('\n').forEach(para => { %>
      <% if (para.trim()) { %><p><%= para %></p><% } %>
    <% }) %>
  </div>

  <!-- Manage Actions (author OR admin) -->
  <% if (canManage) { %>
    <div class="blog-actions">
      <% if (isAuthor) { %>
        <a href="/blogs/<%= blog._id %>/edit" class="btn btn-outline btn-sm">✎ Edit Story</a>
        <form action="/blogs/<%= blog._id %>?_method=DELETE" method="POST"
              onsubmit="return confirm('Delete this story permanently? All comments will be removed.')">
          <button type="submit" class="btn btn-danger btn-sm">✕ Delete</button>
        </form>
      <% } else if (isAdmin) { %>
        <!-- Admin-only action bar (different styling to distinguish) -->
        <div class="admin-action-bar">
          <span class="admin-action-label">🛡️ Admin Actions</span>
          <a href="/blogs/<%= blog._id %>/edit" class="btn btn-admin-edit btn-sm">✎ Edit Blog</a>
          <form action="/blogs/<%= blog._id %>?_method=DELETE" method="POST"
                onsubmit="return confirm('ADMIN: Remove this blog for disciplinary reasons? All comments will also be deleted.')">
            <button type="submit" class="btn btn-admin-delete btn-sm">🚫 Remove Blog</button>
          </form>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- Like Button -->
  <div class="like-section" id="like-section">
    <% if (isAuthenticated) { %>
      <button class="like-btn <%= userLiked ? 'liked' : '' %>" id="like-btn" data-blog-id="<%= blog._id %>">
        <span class="like-icon"><%= userLiked ? '❤️' : '🤍' %></span>
        <span class="like-label"><%= userLiked ? 'Liked' : 'Like' %></span>
        <span class="like-count" id="like-count"><%= likeCount %></span>
      </button>
    <% } else { %>
      <div class="like-btn like-readonly" title="Sign in to like">
        <span class="like-icon">🤍</span>
        <span class="like-label">Likes</span>
        <span class="like-count"><%= likeCount %></span>
      </div>
    <% } %>
  </div>

  <hr class="divider" />

  <!-- Comments Section -->
  <div class="comments-section">
    <h2 class="comments-title">
      Responses
      <span style="color: var(--muted); font-weight: 400; font-size: 1rem; font-family: 'DM Sans', sans-serif;">
        (<%= comments.length %>)
      </span>
    </h2>

    <!-- Add Comment Form -->
    <% if (isAuthenticated) { %>
      <div class="comment-form">
        <h3>Leave a response</h3>
        <form action="/blogs/<%= blog._id %>/comments" method="POST" novalidate>
          <div class="form-group" style="margin-bottom: 1rem;">
            <textarea name="text" class="form-textarea"
              placeholder="Share your thoughts..."
              required maxlength="1000" style="min-height: 100px;"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-sm">Post Response</button>
        </form>
      </div>
    <% } else { %>
      <div style="background: white; border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; text-align: center;">
        <p style="color: var(--muted); margin-bottom: 0.75rem;">Sign in to join the conversation</p>
        <a href="/auth/login" class="btn btn-primary btn-sm">Sign In</a>
        <a href="/auth/register" class="btn btn-outline btn-sm" style="margin-left: 0.5rem;">Register</a>
      </div>
    <% } %>

    <!-- Comments List -->
    <% if (comments.length === 0) { %>
      <div class="no-comments">
        <p>No responses yet. Be the first to share your thoughts.</p>
      </div>
    <% } else { %>
      <div class="comment-list">
        <% comments.forEach(comment => { %>
          <div class="comment <%= isAdmin && (!isAuthenticated || currentUser._id.toString() !== comment.author._id.toString()) ? 'comment-admin-view' : '' %>">
            <div class="comment-header">
              <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
                <span class="comment-author"><%= comment.author ? comment.author.name : 'Unknown' %></span>
                <span class="comment-date">
                  <%= comment.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  · <%= comment.createdAt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                </span>
              </div>

              <div style="display:flex; gap:0.4rem; align-items:center;">
                <!-- Comment owner's own delete button -->
                <% if (isAuthenticated && currentUser._id.toString() === comment.author._id.toString()) { %>
                  <form action="/blogs/<%= blog._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Delete your comment?')" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-xs">✕</button>
                  </form>
                <% } %>

                <!-- Admin delete button (shown even for others' comments) -->
                <% if (isAdmin && currentUser._id.toString() !== comment.author._id.toString()) { %>
                  <form action="/blogs/<%= blog._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('ADMIN: Remove this comment for disciplinary reasons?')" style="display:inline;">
                    <button type="submit" class="btn btn-admin-delete btn-xs" title="Admin: Remove comment">🚫 Remove</button>
                  </form>
                <% } %>
              </div>
            </div>
            <p class="comment-text"><%= comment.text %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div style="margin-top: 3rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
    <a href="/blogs" class="btn btn-outline">← Back to all stories</a>
    <% if (isAdmin) { %>
      <a href="/blogs/admin-dashboard" class="btn btn-admin-edit btn-sm">🛡️ Admin Dashboard</a>
    <% } %>
  </div>
</div>

<script>
  const likeBtn = document.getElementById('like-btn');
  if (likeBtn) {
    likeBtn.addEventListener('click', async () => {
      likeBtn.disabled = true;
      try {
        const res = await fetch(`/blogs/${likeBtn.dataset.blogId}/like`, {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
        });
        const data = await res.json();
        const icon  = likeBtn.querySelector('.like-icon');
        const label = likeBtn.querySelector('.like-label');
        const count = document.getElementById('like-count');
        icon.textContent  = data.liked ? '❤️' : '🤍';
        label.textContent = data.liked ? 'Liked' : 'Like';
        count.textContent = data.count;
        likeBtn.classList.toggle('liked', data.liked);
        // Pulse animation
        likeBtn.classList.add('like-pulse');
        setTimeout(() => likeBtn.classList.remove('like-pulse'), 400);
      } catch (e) { console.error(e); }
      likeBtn.disabled = false;
    });
  }
</script>

<%- include('partials/footer') %>
</body>
</html>
