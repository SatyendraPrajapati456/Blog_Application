    .auth-logos-row { display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-top: 1.75rem; flex-wrap: wrap; }
    .auth-logo-sm { height: 40px; object-fit: contain; border-radius: 6px; background: white; padding: 3px; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
