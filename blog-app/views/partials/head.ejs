    .auth-switch { text-align: center; margin-top: 1.25rem; font-size: 0.88rem; color: var(--muted); }
    .auth-switch a { color: var(--nss-blue); font-weight: 600; text-decoration: none; }
    .auth-switch a:hover { text-decoration: underline; }
    .auth-tagline-row { display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-top: 1.75rem; font-size: 0.78rem; color: var(--muted); font-style: italic; letter-spacing: 0.04em; }
    .input-with-icon { position: relative; }
    .input-icon { position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); font-size: 0.9rem; pointer-events: none; z-index: 1; }
    .input-padded { padding-left: 2.5rem !important; }

    /* ── Responsive auth ── */
    @media (max-width: 800px) {
