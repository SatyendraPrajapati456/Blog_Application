    .footer-logos { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
    .footer-logo { height: 52px; width: 52px; object-fit: contain; border-radius: 6px; background: white; padding: 3px; box-shadow: 0 2px 8px rgba(0,0,0,0.3); transition: transform 0.2s; }
    .footer-logo:hover { transform: scale(1.08); }
