    .pagination .active { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    /* ═══════════════════════════════════════
       MISC
    ═══════════════════════════════════════ */
    .empty-state { text-align: center; padding: 5rem 2rem; }
