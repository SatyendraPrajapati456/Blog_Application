    .auth-logo { width: 72px; height: 72px; object-fit: contain; border-radius: 10px; background: white; padding: 5px; box-shadow: 0 4px 16px rgba(0,0,0,0.35); transition: transform 0.2s; }
    .auth-logo:hover { transform: scale(1.07); }
    .auth-panel-title { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 900; color: white; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 0.4rem; }
    .auth-panel-subtitle { color: rgba(255,255,255,0.65); font-size: 0.88rem; line-height: 1.5; }
