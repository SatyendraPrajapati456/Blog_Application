    .inst-title-sub { font-size: clamp(0.7rem, 1.3vw, 0.82rem); color: rgba(255,255,255,0.7); margin-top: 0.2rem; }
    .inst-tagline { font-size: 0.75rem; color: var(--nss-saffron); margin-top: 0.25rem; letter-spacing: 0.04em; font-style: italic; }

    /* ── NSS Navbar overrides ── */
    .navbar { background: var(--nss-blue) !important; border-bottom: 2px solid var(--nss-orange) !important; }
    .nav-brand { color: white !important; }
    .nav-brand span { color: var(--nss-saffron) !important; }
