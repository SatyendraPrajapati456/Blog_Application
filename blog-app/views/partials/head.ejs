    /* ═══════════════════════════════════════
       PAGINATION
    ═══════════════════════════════════════ */
    .pagination { display: flex; justify-content: center; align-items: center; gap: 0.4rem; margin-top: 3rem; }
    .pagination a, .pagination span {
      padding: 0.5rem 0.875rem; border-radius: 6px;
