<%- include('partials/head') %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="page-wrapper">
  <%- include('partials/sidebar') %>

  <main class="main-content">
  <!-- NSS Hero Banner -->
  <div style="background: linear-gradient(135deg, var(--nss-blue) 0%, var(--nss-blue-mid) 60%, #1b3a6b 100%); border-radius:12px; padding:2rem 2rem 1.75rem; margin-bottom:1.75rem; position:relative; overflow:hidden; border-left:5px solid var(--nss-saffron);">
    <div style="position:absolute; inset:0; background:radial-gradient(circle at 90% 50%, rgba(255,153,51,0.12) 0%, transparent 60%); pointer-events:none;"></div>
    <div style="position:relative; z-index:1; display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap;">
      <img src="/images/nss-logo.jpeg" alt="NSS" style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,153,51,0.5);flex-shrink:0;" />
      <div>
        <div style="font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--nss-saffron); margin-bottom:0.3rem;">National Service Scheme</div>
        <div style="font-family:'Playfair Display',serif; font-size:clamp(1.1rem,2.5vw,1.5rem); font-weight:900; color:white; letter-spacing:-0.02em; line-height:1.2;">Rungta College NSS Blog</div>
        <div style="font-size:0.82rem; color:rgba(255,255,255,0.65); margin-top:0.3rem;">Share stories · Inspire volunteers · Document service</div>
      </div>
      <div style="margin-left:auto; font-style:italic; color:rgba(255,153,51,0.8); font-size:0.9rem; font-family:'Playfair Display',serif;">
        "Not Me But You"
      </div>
    </div>
  </div>

    <!-- Active filter pills -->
    <% if (activeCategory || activeTime || search) { %>
      <div class="filter-pills">
        <% if (activeCategory) { %>
          <a href="/blogs?<%= activeTime ? 'time='+activeTime : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %>" class="filter-pill">
            <%= activeCategory %> ×
          </a>
        <% } %>
        <% if (activeTime) { %>
          <a href="/blogs?<%= activeCategory ? 'category='+activeCategory : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %>" class="filter-pill">
            <%= activeTime === 'today' ? 'Today' : activeTime === 'week' ? 'This Week' : activeTime === 'month' ? 'This Month' : 'This Year' %> ×
          </a>
        <% } %>
        <% if (search) { %>
          <a href="/blogs?<%= activeCategory ? 'category='+activeCategory+'&' : '' %><%= activeTime ? 'time='+activeTime : '' %>" class="filter-pill">
            "<%- search %>" ×
          </a>
        <% } %>
      </div>
    <% } %>

    <div class="section-header">
      <div>
        <h1 style="font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2.2rem); font-weight:900; letter-spacing:-0.03em;">
          <% if (activeCategory) { %>
            <%= activeCategory %> Stories
          <% } else if (search) { %>
            Results for "<%= search %>"
          <% } else { %>
            All Stories
          <% } %>
        </h1>
        <p style="color:var(--muted); font-size:0.9rem; margin-top:0.3rem;">
          <%= total %> <%= total === 1 ? 'story' : 'stories' %> found
        </p>
      </div>
      <% if (isAuthenticated) { %>
        <a href="/blogs/new" class="btn btn-primary btn-sm">+ Write</a>
      <% } %>
    </div>

    <% if (blogs.length === 0) { %>
      <div class="empty-state" style="padding:3rem 1rem;">
        <div class="empty-state-icon">🔍</div>
        <h2>No stories found</h2>
        <p>Try adjusting your filters or search terms.</p>
        <a href="/blogs" class="btn btn-outline btn-sm">Clear filters</a>
      </div>
    <% } else { %>
      <div class="blog-grid">
        <% blogs.forEach(blog => { %>
          <a href="/blogs/<%= blog._id %>" class="blog-card">
            <% if (blog.coverImage) { %>
              <div style="margin: -1.5rem -1.5rem 1.25rem; overflow:hidden; height:170px; border-bottom:1px solid var(--border); border-radius:10px 10px 0 0;">
                <img src="<%= blog.coverImage %>" alt="<%= blog.title %>"
                  style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.3s ease;"
                  onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'" />
              </div>
            <% } %>
            <div class="blog-card-meta">
              <span class="blog-card-author"><%= blog.author ? blog.author.name : 'Unknown' %></span>
              <span class="blog-card-sep">·</span>
              <span class="blog-card-date">
                <%= blog.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </span>
            </div>
            <h2><%= blog.title %></h2>
            <p><%= blog.excerpt %></p>
            <div class="blog-card-footer">
              <span class="read-more">Read more →</span>
              <% if (blog.category) { %>
                <span class="category-badge"><%= blog.category %></span>
              <% } %>
            </div>
          </a>
        <% }) %>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %><%= activeCategory ? '&category='+activeCategory : '' %><%= activeTime ? '&time='+activeTime : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %>">← Prev</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="active"><%= i %></span>
            <% } else { %>
              <a href="?page=<%= i %><%= activeCategory ? '&category='+activeCategory : '' %><%= activeTime ? '&time='+activeTime : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %>"><%= i %></a>
            <% } %>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %><%= activeCategory ? '&category='+activeCategory : '' %><%= activeTime ? '&time='+activeTime : '' %><%= search ? '&search='+encodeURIComponent(search) : '' %>">Next →</a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </main>
</div>

<%- include('partials/footer') %>
</body>
</html>
